# Copy to .env in the repository root (used by docker-compose for the API service).
# For local `uvicorn` without Docker, you can also place a .env under apps/api/ per FastAPI settings.

# --- FastAPI (apps/api) ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/admin_panel
SECRET_KEY=replace-with-a-long-random-string-min-32-chars
ENVIRONMENT=development
DEBUG=false
REDIS_URL=redis://localhost:6379/0
# JSON array of allowed browser origins, e.g. CORS for the Vite app
CORS_ORIGINS=["http://localhost:5173","http://localhost:80"]

# --- React (apps/web) — Vite: prefix with VITE_ ---
# In production, set to your public API base URL (no trailing slash on path if your client adds /api).
VITE_API_URL=http://localhost:8000/api/v1
